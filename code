    <div id="toast-container" class="fixed bottom-6 right-6 z-50 flex flex-col gap-2 max-w-sm pointer-events-none"></div>

    <script>
        // Default Sample Data (Provides instant utility upon launch)
        const defaultItems = [
            {
                id: "1",
                title: "Inception",
                type: "movie",
                status: "In Progress",
                priority: "High",
                rating: 4,
                year: 2010,
