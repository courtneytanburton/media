<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OmniShelf - Ultimate Media Backlog Tracker</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        brand: {
                            movies: '#ef4444',  /* Red */
                            tv: '#f59e0b',      /* Amber */
                            games: '#6366f1',   /* Indigo */
                            music: '#10b981'    /* Emerald */
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <!-- Inter Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Chart.js for beautiful stats -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        body {
            font-family: 'Inter', sans-serif;
            transition: background-color 0.3s, color 0.3s;
        }
        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        .dark ::-webkit-scrollbar-thumb {
            background: #334155;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        /* Card hover effects */
        .media-card {
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .media-card:hover {
            transform: translateY(-4px);
        }
        /* Glow accents for categories */
        .glow-movies:hover { box-shadow: 0 10px 25px -5px rgba(239, 68, 68, 0.15); }
        .glow-tv:hover { box-shadow: 0 10px 25px -5px rgba(245, 158, 11, 0.15); }
        .glow-games:hover { box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.15); }
        .glow-music:hover { box-shadow: 0 10px 25px -5px rgba(16, 185, 129, 0.15); }
    </style>
</head>

<body class="bg-slate-50 text-slate-800 dark:bg-slate-950 dark:text-slate-100 min-h-screen pb-12">
    <!-- Navigation Bar -->
    <header class="sticky top-0 z-40 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 transition-colors">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-gradient-to-tr from-indigo-500 via-purple-500 to-pink-500 rounded-xl flex items-center justify-center shadow-lg shadow-indigo-500/20 text-white">
                    <i class="fa-solid fa-layer-group text-lg"></i>
                </div>
                <div>
                    <h1 class="font-extrabold text-xl tracking-tight bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 bg-clip-text text-transparent">OmniShelf</h1>
                    <p class="text-xs text-slate-500 dark:text-slate-400 font-medium">Ultimate Entertainment Watchlist</p>
                </div>
            </div>

            <!-- Header Controls -->
            <div class="flex items-center gap-2 sm:gap-4">
                <!-- Randomizer Button -->
                <button onclick="pickRandomItem()" class="flex items-center gap-2 px-3.5 py-2 rounded-xl text-sm font-semibold bg-indigo-50 dark:bg-indigo-950/40 text-indigo-600 dark:text-indigo-400 border border-indigo-100 dark:border-indigo-900/50 hover:bg-indigo-100 dark:hover:bg-indigo-950/80 transition-all shadow-sm group">
                    <i class="fa-solid fa-dice group-hover:rotate-45 transition-transform"></i>
                    <span class="hidden sm:inline">Pick For Me!</span>
                </button>

                <!-- Add New Button -->
                <button onclick="openAddModal()" class="flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-semibold bg-slate-900 dark:bg-white text-white dark:text-slate-950 hover:bg-slate-800 dark:hover:bg-slate-100 transition-all shadow-md">
                    <i class="fa-solid fa-plus"></i>
                    <span>Add Item</span>
                </button>

                <!-- Theme Toggle Button -->
                <button onclick="toggleTheme()" class="w-10 h-10 rounded-xl flex items-center justify-center border border-slate-200 dark:border-slate-800 hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-600 dark:text-slate-300 transition-all">
                    <i id="theme-icon" class="fa-solid fa-moon"></i>
                </button>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
        <!-- Quick Stats Accordion Header / Overview -->
        <section class="mb-8">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-4">
                <div>
                    <h2 class="text-2xl font-bold tracking-tight">Dashboard</h2>
                    <p class="text-sm text-slate-500 dark:text-slate-400">Track and manage your media journey across all screens and speakers.</p>
                </div>
                <button onclick="toggleStats()" class="text-sm font-semibold text-indigo-600 dark:text-indigo-400 hover:underline flex items-center gap-1.5">
                    <span id="stats-toggle-text">Hide Dashboard Analytics</span>
                    <i id="stats-toggle-icon" class="fa-solid fa-chevron-up text-xs transition-transform"></i>
                </button>
            </div>

            <!-- Stats Analytics Grid Container -->
            <div id="stats-container" class="grid grid-cols-1 md:grid-cols-4 gap-6 transition-all duration-300 overflow-hidden max-h-[1000px]">
                <!-- Stats Summary Cards -->
                <div class="md:col-span-3 grid grid-cols-2 lg:grid-cols-4 gap-4">
                    <!-- Cards -->
                    <div class="bg-white dark:bg-slate-900 p-4 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col justify-between">
                        <div class="flex items-center justify-between text-slate-400">
                            <span class="text-xs font-semibold uppercase tracking-wider">Total Items</span>
                            <i class="fa-solid fa-database text-lg"></i>
                        </div>
                        <div class="mt-4">
                            <h3 id="stat-total" class="text-3xl font-bold tracking-tight">0</h3>
                            <p class="text-xs text-slate-500 mt-1">Across 4 formats</p>
                        </div>
                    </div>
                    
                    <div class="bg-white dark:bg-slate-900 p-4 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col justify-between">
                        <div class="flex items-center justify-between text-indigo-500">
                            <span class="text-xs font-semibold uppercase tracking-wider text-slate-400">In Progress</span>
                            <i class="fa-solid fa-spinner text-lg animate-spin-slow"></i>
                        </div>
                        <div class="mt-4">
                            <h3 id="stat-progress" class="text-3xl font-bold tracking-tight text-indigo-600 dark:text-indigo-400">0</h3>
                            <p class="text-xs text-slate-500 mt-1">Currently diving in</p>
                        </div>
                    </div>

                    <div class="bg-white dark:bg-slate-900 p-4 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col justify-between">
                        <div class="flex items-center justify-between text-emerald-500">
                            <span class="text-xs font-semibold uppercase tracking-wider text-slate-400">Completed</span>
                            <i class="fa-solid fa-circle-check text-lg"></i>
                        </div>
                        <div class="mt-4">
                            <h3 id="stat-completed" class="text-3xl font-bold tracking-tight text-emerald-600 dark:text-emerald-400">0</h3>
                            <p id="stat-completed-pct" class="text-xs text-emerald-500 font-medium mt-1">0% completion rate</p>
                        </div>
                    </div>

                    <div class="bg-white dark:bg-slate-900 p-4 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col justify-between">
                        <div class="flex items-center justify-between text-rose-500">
                            <span class="text-xs font-semibold uppercase tracking-wider text-slate-400">Unstarted</span>
                            <i class="fa-solid fa-clock text-lg"></i>
                        </div>
                        <div class="mt-4">
                            <h3 id="stat-unstarted" class="text-3xl font-bold tracking-tight text-rose-600 dark:text-rose-400">0</h3>
                            <p class="text-xs text-slate-500 mt-1">Waiting in the wings</p>
                        </div>
                    </div>
                </div>

                <!-- Visual Breakdown Chart -->
                <div class="bg-white dark:bg-slate-900 p-4 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col justify-center items-center">
                    <span class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2 self-start">Media Breakdown</span>
                    <div class="w-full h-32 flex items-center justify-center">
                        <canvas id="mediaChart"></canvas>
                    </div>
                </div>
            </div>
        </section>

        <!-- Content Navigation / Filter Control Bar -->
        <section class="mb-8 bg-white dark:bg-slate-900 p-4 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col gap-4">
            <!-- Media Category Selector tabs -->
            <div class="flex items-center justify-between border-b border-slate-100 dark:border-slate-800 pb-3 flex-wrap gap-4">
                <nav class="flex gap-1 overflow-x-auto w-full md:w-auto -mx-4 px-4 md:mx-0 md:px-0">
                    <button onclick="setCategoryFilter('all')" id="tab-all" class="category-tab px-4 py-2 text-sm font-semibold rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-white flex items-center gap-2 shrink-0 transition-all">
                        <i class="fa-solid fa-border-all"></i> All Media
                    </button>
                    <button onclick="setCategoryFilter('movie')" id="tab-movie" class="category-tab px-4 py-2 text-sm font-medium rounded-xl text-slate-500 hover:text-slate-800 dark:hover:text-slate-200 flex items-center gap-2 shrink-0 transition-all">
                        <i class="fa-solid fa-film text-brand-movies"></i> Movies
                    </button>
                    <button onclick="setCategoryFilter('tv')" id="tab-tv" class="category-tab px-4 py-2 text-sm font-medium rounded-xl text-slate-500 hover:text-slate-800 dark:hover:text-slate-200 flex items-center gap-2 shrink-0 transition-all">
                        <i class="fa-solid fa-tv text-brand-tv"></i> TV Shows
                    </button>
                    <button onclick="setCategoryFilter('game')" id="tab-game" class="category-tab px-4 py-2 text-sm font-medium rounded-xl text-slate-500 hover:text-slate-800 dark:hover:text-slate-200 flex items-center gap-2 shrink-0 transition-all">
                        <i class="fa-solid fa-gamepad text-brand-games"></i> Video Games
                    </button>
                    <button onclick="setCategoryFilter('music')" id="tab-music" class="category-tab px-4 py-2 text-sm font-medium rounded-xl text-slate-500 hover:text-slate-800 dark:hover:text-slate-200 flex items-center gap-2 shrink-0 transition-all">
                        <i class="fa-solid fa-music text-brand-music"></i> Music
                    </button>
                </nav>

                <!-- View Mode and Display Options -->
                <div class="flex items-center gap-2 ml-auto">
                    <!-- Grid/List View Toggles -->
                    <button onclick="setViewMode('grid')" id="btn-grid-view" class="w-9 h-9 rounded-lg flex items-center justify-center bg-indigo-50 dark:bg-indigo-950/30 text-indigo-600 dark:text-indigo-400 border border-indigo-100 dark:border-indigo-900/50 transition-all" title="Grid View">
                        <i class="fa-solid fa-grid-2"></i>
                        <i class="fa-solid fa-grip-vertical"></i>
                    </button>
                    <button onclick="setViewMode('list')" id="btn-list-view" class="w-9 h-9 rounded-lg flex items-center justify-center text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-all" title="List View">
                        <i class="fa-solid fa-list"></i>
                    </button>
                </div>
            </div>

            <!-- Detailed Search, Sorting, and Filters -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                <!-- Search bar -->
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400">
                        <i class="fa-solid fa-magnifying-glass text-sm"></i>
                    </span>
                    <input type="text" id="filter-search" oninput="handleFilterChange()" placeholder="Search titles, artist, notes..." class="w-full pl-9 pr-4 py-2 text-sm rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all">
                </div>

                <!-- Filter by Status -->
                <div>
                    <select id="filter-status" onchange="handleFilterChange()" class="w-full px-3 py-2 text-sm rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all">
                        <option value="all">All Statuses</option>
                        <option value="Not Started">Not Started</option>
                        <option value="In Progress">In Progress</option>
                        <option value="Completed">Completed</option>
                        <option value="Abandoned">On Hold / Abandoned</option>
                    </select>
                </div>

                <!-- Filter by Priority -->
                <div>
                    <select id="filter-priority" onchange="handleFilterChange()" class="w-full px-3 py-2 text-sm rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all">
                        <option value="all">All Priorities</option>
                        <option value="High">🔥 High Priority</option>
                        <option value="Medium">⚡ Medium Priority</option>
                        <option value="Low">💤 Low Priority</option>
                    </select>
                </div>

                <!-- Sort options -->
                <div>
                    <select id="filter-sort" onchange="handleFilterChange()" class="w-full px-3 py-2 text-sm rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all">
                        <option value="date-new">Newest Added First</option>
                        <option value="date-old">Oldest Added First</option>
                        <option value="title-asc">Alphabetical (A-Z)</option>
                        <option value="title-desc">Alphabetical (Z-A)</option>
                        <option value="rating-desc">Rating: High to Low</option>
                        <option value="priority-desc">Priority: High to Low</option>
                    </select>
                </div>
            </div>
        </section>

        <!-- Main Media Shelf Layout -->
        <section>
            <!-- No items template (Hidden by default) -->
            <div id="no-items-state" class="hidden flex-col items-center justify-center py-20 bg-white dark:bg-slate-900 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-sm text-center px-4">
                <div class="w-16 h-16 bg-slate-100 dark:bg-slate-800 rounded-2xl flex items-center justify-center text-slate-400 text-2xl mb-4">
                    <i class="fa-solid fa-folder-open"></i>
                </div>
                <h3 class="font-bold text-lg">No media found</h3>
                <p class="text-slate-400 text-sm max-w-sm mt-1">Try refining your search keywords/filters or insert a new item into your shelf list!</p>
                <button onclick="openAddModal()" class="mt-6 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium text-sm rounded-xl transition-all shadow-md shadow-indigo-600/10">
                    Add First Item
                </button>
            </div>

            <!-- Card Grid View Container -->
            <div id="media-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <!-- Javascript dynamically injects cards here -->
            </div>

            <!-- List View Container (Hidden initially) -->
            <div id="media-list" class="hidden overflow-hidden bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-800">
                        <thead class="bg-slate-50 dark:bg-slate-900/50">
                            <tr>
                                <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Media & Title</th>
                                <th scope="col" class="px-6 py-4 class-hidden-sm text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Format</th>
                                <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Status</th>
                                <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Priority</th>
                                <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Rating</th>
                                <th scope="col" class="px-6 py-4 text-right text-xs font-semibold text-slate-400 uppercase tracking-wider">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="list-tbody" class="divide-y divide-slate-200 dark:divide-slate-800">
                            <!-- Javascript dynamically injects rows here -->
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    </main>

    <!-- Add/Edit Media Modal -->
    <div id="media-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-slate-950/60 backdrop-blur-sm">
        <div class="bg-white dark:bg-slate-900 w-full max-w-2xl rounded-2xl shadow-2xl border border-slate-200 dark:border-slate-800 overflow-hidden flex flex-col max-h-[90vh] scale-95 transition-all" id="modal-content">
            <!-- Modal Header -->
            <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800 flex justify-between items-center">
                <h3 id="modal-title" class="text-lg font-bold">Add New Entry</h3>
                <button onclick="closeModal()" class="w-8 h-8 rounded-full flex items-center justify-center hover:bg-slate-100 dark:hover:bg-slate-800 transition-all text-slate-400 hover:text-slate-600 dark:hover:text-slate-200">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <!-- Modal Form -->
            <form id="media-form" onsubmit="handleFormSubmit(event)" class="overflow-y-auto p-6 space-y-5">
                <input type="hidden" id="item-id">

                <!-- Title & Type -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label for="item-title" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Title *</label>
                        <input type="text" id="item-title" required placeholder="Inception, Elden Ring, Dark Side of the Moon..." class="w-full px-4 py-2 text-sm rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all">
                    </div>
                    <div>
                        <label for="item-type" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Media Type *</label>
                        <select id="item-type" onchange="adaptFormFields()" class="w-full px-4 py-2 text-sm rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all">
                            <option value="movie">🎬 Movie</option>
                            <option value="tv">📺 TV Show</option>
                            <option value="game">🎮 Video Game</option>
                            <option value="music">🎵 Music</option>
                        </select>
                    </div>
                </div>

                <!-- Status, Priority & Rating -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div>
                        <label for="item-status" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Status</label>
                        <select id="item-status" class="w-full px-4 py-2 text-sm rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all">
                            <option value="Not Started">Not Started</option>
                            <option value="In Progress">In Progress</option>
                            <option value="Completed">Completed</option>
                            <option value="Abandoned">On Hold / Abandoned</option>
                        </select>
                    </div>
                    <div>
                        <label for="item-priority" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Priority</label>
                        <select id="item-priority" class="w-full px-4 py-2 text-sm rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all">
                            <option value="High">🔥 High</option>
                            <option value="Medium">⚡ Medium</option>
                            <option value="Low">💤 Low</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Rating</label>
                        <div class="flex items-center gap-1.5 h-10">
                            <input type="hidden" id="item-rating" value="0">
                            <!-- 5 Interactive Star Icons -->
                            <div class="flex text-lg text-slate-300 dark:text-slate-700">
                                <button type="button" onclick="setRatingValue(1)" class="star-btn transition-transform hover:scale-110"><i class="fa-solid fa-star"></i></button>
                                <button type="button" onclick="setRatingValue(2)" class="star-btn transition-transform hover:scale-110"><i class="fa-solid fa-star"></i></button>
                                <button type="button" onclick="setRatingValue(3)" class="star-btn transition-transform hover:scale-110"><i class="fa-solid fa-star"></i></button>
                                <button type="button" onclick="setRatingValue(4)" class="star-btn transition-transform hover:scale-110"><i class="fa-solid fa-star"></i></button>
                                <button type="button" onclick="setRatingValue(5)" class="star-btn transition-transform hover:scale-110"><i class="fa-solid fa-star"></i></button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- DYNAMIC MEDIA TYPE FIELDS -->
                <!-- Dynamic: Movie Fields -->
                <div id="fields-movie" class="dynamic-media-fields grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label for="movie-director" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Director</label>
                        <input type="text" id="movie-director" placeholder="Christopher Nolan" class="w-full px-4 py-2 text-sm rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all">
                    </div>
                    <div>
                        <label for="movie-runtime" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Runtime (Minutes)</label>
                        <input type="number" id="movie-runtime" placeholder="148" min="0" class="w-full px-4 py-2 text-sm rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all">
                    </div>
                </div>

                <!-- Dynamic: TV Show Fields -->
                <div id="fields-tv" class="dynamic-media-fields hidden grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label for="tv-season" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Current Season</label>
                        <input type="number" id="tv-season" placeholder="1" min="1" class="w-full px-4 py-2 text-sm rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all">
                    </div>
                    <div>
                        <label for="tv-episode" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Current Episode</label>
