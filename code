            },
            {
                id: "4",
                title: "Discovery",
                type: "music",
                status: "Completed",
                priority: "Low",
                rating: 5,
                year: 2001,
                image: "https://images.unsplash.com/photo-1614613535308-eb5fbd3d2c17?auto=format&fit=crop&w=400&q=80",
                notes: "Classic house masterpiece. Truly timeless.",
                artist: "Daft Punk",
                format: "Album",
                dateAdded: "2026-05-20T11:45:00.000Z"
            }
        ];

        // State variables
        let mediaItems = JSON.parse(localStorage.getItem('omnishelf_media')) || defaultItems;
        let currentFilterCategory = 'all';
        let currentViewMode = 'grid';
        let chartInstance = null;

        // Save State
        function saveToStorage() {
            localStorage.setItem('omnishelf_media', JSON.stringify(mediaItems));
            updateStatsDashboard();
        }

        // Dark/Light Theme Manager
        function toggleTheme() {
            const html = document.documentElement;
            const icon = document.getElementById('theme-icon');
            if (html.classList.contains('dark')) {
                html.classList.remove('dark');
                icon.className = "fa-solid fa-sun";
                localStorage.setItem('theme', 'light');
            } else {
                html.classList.add('dark');
                icon.className = "fa-solid fa-moon";
                localStorage.setItem('theme', 'dark');
            }
        }

        function initTheme() {
            const savedTheme = localStorage.getItem('theme');
            const html = document.documentElement;
            const icon = document.getElementById('theme-icon');
            if (savedTheme === 'light') {
                html.classList.remove('dark');
                icon.className = "fa-solid fa-sun";
            } else {
                html.classList.add('dark');
                icon.className = "fa-solid fa-moon";
            }
        }

        // Generate customized badge color utilities based on media types
        function getCategoryBadge(type) {
            const badges = {
                movie: `<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-semibold bg-red-100 text-red-800 dark:bg-red-950/40 dark:text-red-400"><i class="fa-solid fa-film"></i> Movie</span>`,
                tv: `<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-semibold bg-amber-100 text-amber-800 dark:bg-amber-950/40 dark:text-amber-400"><i class="fa-solid fa-tv"></i> TV</span>`,
                game: `<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-semibold bg-indigo-100 text-indigo-800 dark:bg-indigo-950/40 dark:text-indigo-400"><i class="fa-solid fa-gamepad"></i> Game</span>`,
                music: `<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-semibold bg-emerald-100 text-emerald-800 dark:bg-emerald-950/40 dark:text-emerald-400"><i class="fa-solid fa-music"></i> Music</span>`
            };
            return badges[type] || '';
        }

        // Return rating HTML (Stars display)
        function renderStars(rating, size = 'sm') {
            let starsHtml = `<div class="flex text-${size} gap-0.5">`;
            for (let i = 1; i <= 5; i++) {
                if (i <= rating) {
                    starsHtml += `<i class="fa-solid fa-star text-amber-400"></i>`;
                } else {
                    starsHtml += `<i class="fa-regular fa-star text-slate-300 dark:text-slate-600"></i>`;
                }
            }
            starsHtml += '</div>';
            return starsHtml;
        }

        // Return status badge with elegant borders
        function getStatusBadge(status) {
            switch (status) {
                case 'Completed':
                    return `<span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-emerald-100 dark:bg-emerald-950/40 text-emerald-800 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-900/40">Completed</span>`;
                case 'In Progress':
                    return `<span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-blue-100 dark:bg-blue-950/40 text-blue-800 dark:text-blue-400 border border-blue-200 dark:border-blue-900/40">In Progress</span>`;
                case 'Abandoned':
                    return `<span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 border border-slate-200 dark:border-slate-700">On Hold</span>`;
                default: // Not Started
                    return `<span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-rose-50 dark:bg-rose-950/20 text-rose-600 dark:text-rose-400 border border-rose-100 dark:border-rose-900/30">Not Started</span>`;
            }
        }

        // Get priority colored tags
        function getPriorityTag(priority) {
            switch (priority) {
                case 'High':
                    return `<span class="text-xs font-semibold text-rose-500 flex items-center gap-1"><i class="fa-solid fa-fire-flame-curved"></i> High</span>`;
                case 'Medium':
                    return `<span class="text-xs font-semibold text-amber-500 flex items-center gap-1"><i class="fa-solid fa-bolt"></i> Medium</span>`;
                default:
                    return `<span class="text-xs font-semibold text-slate-400 flex items-center gap-1"><i class="fa-solid fa-zzz"></i> Low</span>`;
            }
        }

        // Generate modern generative background gradient based on ID
        function generateFallBackImage(title, type) {
            const grads = [
                'from-pink-500 to-indigo-500',
                'from-violet-600 to-red-400',
                'from-emerald-400 to-teal-700',
                'from-yellow-400 to-orange-600',
                'from-fuchsia-600 to-pink-500',
                'from-blue-600 to-cyan-500'
            ];
            const sum = title.split('').reduce((acc, char) => acc + char.charCodeAt(0), 0);
            const selectedGrad = grads[sum % grads.length];
            const icons = { movie: 'film', tv: 'tv', game: 'gamepad', music: 'music' };
            const icon = icons[type] || 'layer-group';

            return `
                <div class="w-full h-full bg-gradient-to-tr ${selectedGrad} flex flex-col justify-center items-center p-4 text-white select-none">
                    <i class="fa-solid fa-${icon} text-4xl mb-3 opacity-80"></i>
                    <span class="font-bold text-center text-sm line-clamp-2">${title}</span>
                </div>
            `;
        }

        function toggleStats() {
            const container = document.getElementById('stats-container');
            const toggleText = document.getElementById('stats-toggle-text');
            const toggleIcon = document.getElementById('stats-toggle-icon');

            if (container.classList.contains('max-h-0')) {
                container.classList.remove('max-h-0', 'mb-0');
                container.classList.add('max-h-[1000px]');
                toggleText.innerText = "Hide Dashboard Analytics";
                toggleIcon.classList.remove('rotate-180');
            } else {
                container.classList.remove('max-h-[1000px]');
                container.classList.add('max-h-0', 'mb-0');
                toggleText.innerText = "Show Dashboard Analytics";
                toggleIcon.classList.add('rotate-180');
            }
        }

        function updateStatsDashboard() {
            const total = mediaItems.length;
            const progress = mediaItems.filter(i => i.status === 'In Progress').length;
            const completed = mediaItems.filter(i => i.status === 'Completed').length;
            const unstarted = mediaItems.filter(i => i.status === 'Not Started').length;

            document.getElementById('stat-total').innerText = total;
            document.getElementById('stat-progress').innerText = progress;
            document.getElementById('stat-completed').innerText = completed;
            document.getElementById('stat-unstarted').innerText = unstarted;

            const completionPct = total > 0 ? Math.round((completed / total) * 100) : 0;
            document.getElementById('stat-completed-pct').innerText = `${completionPct}% completion rate`;

            // Setup Chart.js Analytics
            const countMap = { movie: 0, tv: 0, game: 0, music: 0 };
            mediaItems.forEach(i => {
                if (countMap[i.type] !== undefined) countMap[i.type]++;
            });

            const ctx = document.getElementById('mediaChart').getContext('2d');
            if (chartInstance) {
                chartInstance.destroy();
            }

            chartInstance = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Movies', 'TV Shows', 'Games', 'Music'],
                    datasets: [{
                        data: [countMap.movie, countMap.tv, countMap.game, countMap.music],
                        backgroundColor: ['#ef4444', '#f59e0b', '#6366f1', '#10b981'],
                        borderWidth: 0,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            position: 'right',
                            labels: {
                                color: document.documentElement.classList.contains('dark') ? '#94a3b8' : '#475569',
                                boxWidth: 12,
                                font: { size: 10, weight: 'bold' }
                            }
                        }
                    },
                    cutout: '70%'
                }
            });
        }

        function showToast(message, type = 'info') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            
            const icons = {
                success: 'fa-circle-check text-emerald-500',
                error: 'fa-circle-xmark text-rose-500',
                info: 'fa-circle-info text-blue-500'
            };

            toast.className = "flex items-center gap-3 p-4 rounded-xl shadow-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 transform translate-y-2 opacity-0 transition-all duration-300 pointer-events-auto max-w-sm";
            toast.innerHTML = `
                <i class="fa-solid ${icons[type]} text-lg shrink-0"></i>
                <div class="text-sm font-medium text-slate-700 dark:text-slate-300">${message}</div>
            `;

            container.appendChild(toast);

            // Trigger animation
            setTimeout(() => {
                toast.classList.remove('translate-y-2', 'opacity-0');
            }, 10);

            // Clear after 3 seconds
            setTimeout(() => {
                toast.classList.add('translate-y-2', 'opacity-0');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        function setCategoryFilter(category) {
            currentFilterCategory = category;
            
            // Manage Active Styling
            document.querySelectorAll('.category-tab').forEach(tab => {
                tab.className = "category-tab px-4 py-2 text-sm font-medium rounded-xl text-slate-500 hover:text-slate-800 dark:hover:text-slate-200 flex items-center gap-2 shrink-0 transition-all";
            });

            const activeTab = document.getElementById(`tab-${category}`);
            if (activeTab) {
                activeTab.className = "category-tab px-4 py-2 text-sm font-semibold rounded-xl bg-indigo-600 dark:bg-indigo-600 text-white flex items-center gap-2 shrink-0 transition-all shadow-md shadow-indigo-600/10";
            }

            renderContent();
        }

        function setViewMode(mode) {
            currentViewMode = mode;
            const gridBtn = document.getElementById('btn-grid-view');
            const listBtn = document.getElementById('btn-list-view');

            if (mode === 'grid') {
                gridBtn.className = "w-9 h-9 rounded-lg flex items-center justify-center bg-indigo-50 dark:bg-indigo-950/30 text-indigo-600 dark:text-indigo-400 border border-indigo-100 dark:border-indigo-900/50 transition-all";
                listBtn.className = "w-9 h-9 rounded-lg flex items-center justify-center text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-all";
                document.getElementById('media-grid').classList.remove('hidden');
                document.getElementById('media-list').classList.add('hidden');
            } else {
                listBtn.className = "w-9 h-9 rounded-lg flex items-center justify-center bg-indigo-50 dark:bg-indigo-950/30 text-indigo-600 dark:text-indigo-400 border border-indigo-100 dark:border-indigo-900/50 transition-all";
                gridBtn.className = "w-9 h-9 rounded-lg flex items-center justify-center text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-all";
                document.getElementById('media-grid').classList.add('hidden');
                document.getElementById('media-list').classList.remove('hidden');
            }

            renderContent();
        }

        function handleFilterChange() {
            renderContent();
        }

        // Filter and Sort Data
        function getFilteredAndSortedItems() {
            let items = [...mediaItems];

            // 1. Category Filter
            if (currentFilterCategory !== 'all') {
                items = items.filter(i => i.type === currentFilterCategory);
            }

            // 2. Search Keyword
            const query = document.getElementById('filter-search').value.toLowerCase().trim();
            if (query) {
                items = items.filter(i => {
                    return (
                        i.title.toLowerCase().includes(query) ||
                        (i.notes && i.notes.toLowerCase().includes(query)) ||
                        (i.director && i.director.toLowerCase().includes(query)) ||
                        (i.artist && i.artist.toLowerCase().includes(query)) ||
                        (i.platform && i.platform.toLowerCase().includes(query))
                    );
                });
            }

            // 3. Status Filter
            const status = document.getElementById('filter-status').value;
            if (status !== 'all') {
                items = items.filter(i => i.status === status);
            }

            // 4. Priority Filter
            const priority = document.getElementById('filter-priority').value;
            if (priority !== 'all') {
                items = items.filter(i => i.priority === priority);
            }

            // 5. Sorting
            const sort = document.getElementById('filter-sort').value;
            items.sort((a, b) => {
                if (sort === 'date-new') {
                    return new Date(b.dateAdded || 0) - new Date(a.dateAdded || 0);
                } else if (sort === 'date-old') {
                    return new Date(a.dateAdded || 0) - new Date(b.dateAdded || 0);
                } else if (sort === 'title-asc') {
                    return a.title.localeCompare(b.title);
                } else if (sort === 'title-desc') {
                    return b.title.localeCompare(a.title);
                } else if (sort === 'rating-desc') {
                    return b.rating - a.rating;
                } else if (sort === 'priority-desc') {
                    const priorityWeight = { High: 3, Medium: 2, Low: 1 };
                    return (priorityWeight[b.priority] || 0) - (priorityWeight[a.priority] || 0);
                }
                return 0;
            });

            return items;
        }

        // Render Cards / Grid list items
        function renderContent() {
            const items = getFilteredAndSortedItems();
            const noItemsState = document.getElementById('no-items-state');
            const mediaGrid = document.getElementById('media-grid');
            const mediaList = document.getElementById('media-list');

            if (items.length === 0) {
                noItemsState.classList.remove('hidden');
                mediaGrid.classList.add('hidden');
                mediaList.classList.add('hidden');
                return;
            } else {
                noItemsState.classList.add('hidden');
                if (currentViewMode === 'grid') {
                    mediaGrid.classList.remove('hidden');
                } else {
                    mediaList.classList.remove('hidden');
                }
            }

            if (currentViewMode === 'grid') {
                renderGridView(items);
            } else {
                renderListView(items);
            }
        }

        function renderGridView(items) {
            const grid = document.getElementById('media-grid');
            grid.innerHTML = '';

            items.forEach(item => {
                const card = document.createElement('div');
                card.className = `media-card bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden flex flex-col glow-${item.type}`;
                
                // Construct Contextual Details block
                let contextHtml = '';
                if (item.type === 'movie') {
                    contextHtml = `
                        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1 line-clamp-1">
                            Director: <span class="font-medium text-slate-700 dark:text-slate-300">${item.director || 'Unknown'}</span>
                        </p>
                        ${item.runtime ? `<p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5"><i class="fa-regular fa-clock mr-1"></i> ${item.runtime} mins</p>` : ''}
                    `;
                } else if (item.type === 'tv') {
                    contextHtml = `
                        <div class="mt-2 flex items-center justify-between bg-slate-50 dark:bg-slate-950/40 p-2 rounded-xl border border-slate-100 dark:border-slate-800/80">
                            <span class="text-xs font-semibold text-slate-500">Season ${item.season || 1}, Ep ${item.episode || 0}</span>
                            <div class="flex gap-1">
                                <button onclick="changeProgress('${item.id}', -1, event)" class="w-6 h-6 rounded-md bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 flex items-center justify-center hover:bg-slate-100 text-xs shadow-sm"><i class="fa-solid fa-minus"></i></button>
                                <button onclick="changeProgress('${item.id}', 1, event)" class="w-6 h-6 rounded-md bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 flex items-center justify-center hover:bg-slate-100 text-xs shadow-sm"><i class="fa-solid fa-plus"></i></button>
                            </div>
                        </div>
                    `;
                } else if (item.type === 'game') {
                    const progressPercent = item.progress || 0;
                    contextHtml = `
                        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1 line-clamp-1">
                            Platform: <span class="font-medium text-slate-700 dark:text-slate-300">${item.platform || 'General'}</span>
                        </p>
                        <div class="mt-2">
                            <div class="flex justify-between items-center text-[10px] font-bold text-slate-400 mb-1">
                                <span>COMPLETION</span>
                                <span>${progressPercent}%</span>
                            </div>
                            <div class="w-full h-1.5 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                                <div class="h-full bg-brand-games" style="width: ${progressPercent}%"></div>
                            </div>
                        </div>
                    `;
                } else if (item.type === 'music') {
                    contextHtml = `
                        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1 line-clamp-1">
                            Artist: <span class="font-medium text-slate-700 dark:text-slate-300">${item.artist || 'Unknown'}</span>
                        </p>
                        ${item.format ? `<span class="inline-block mt-1 text-[10px] font-semibold bg-emerald-50 dark:bg-emerald-950/20 text-emerald-600 dark:text-emerald-400 border border-emerald-100 dark:border-emerald-900/40 px-2 py-0.5 rounded">${item.format}</span>` : ''}
                    `;
                }

                card.innerHTML = `
                    <!-- Cover image section -->
                    <div class="relative h-44 w-full bg-slate-100 dark:bg-slate-950 border-b border-slate-200 dark:border-slate-800/80 overflow-hidden flex-shrink-0">
                        ${item.image ? `<img src="${item.image}" alt="${item.title}" class="w-full h-full object-cover transition-transform duration-500 hover:scale-110" onerror="this.outerHTML=\`${generateFallBackImage(item.title, item.type)}\`"/>` : generateFallBackImage(item.title, item.type)}
                        <div class="absolute top-3 left-3 flex flex-col gap-1.5 items-start">
                            ${getCategoryBadge(item.type)}
                        </div>
                        <div class="absolute bottom-3 right-3">
                            ${getStatusBadge(item.status)}
                        </div>
                    </div>
                    <!-- Body Content -->
                    <div class="p-5 flex-1 flex flex-col justify-between">
                        <div>
                            <div class="flex justify-between items-start gap-2">
                                <h4 class="font-bold text-base leading-snug line-clamp-1 text-slate-900 dark:text-white" title="${item.title}">${item.title}</h4>
                                <span class="text-xs text-slate-400 font-semibold mt-0.5 shrink-0">${item.year ? item.year : ''}</span>
                            </div>
                            <!-- Star Ratings & Priority -->
                            <div class="flex items-center justify-between mt-2">
                                ${renderStars(item.rating)}
                                ${getPriorityTag(item.priority)}
                            </div>
                            <!-- Context field descriptors -->
                            <div class="mt-3">
                                ${contextHtml}
                            </div>
                            <!-- User Notes -->
                            ${item.notes ? `<p class="mt-4 text-xs text-slate-400 dark:text-slate-500 line-clamp-2 border-t border-slate-100 dark:border-slate-800/60 pt-3 italic">"${item.notes}"</p>` : ''}
                        </div>
                        
                        <!-- Actions panel -->
                        <div class="flex items-center justify-end gap-2 border-t border-slate-100 dark:border-slate-800/80 pt-4 mt-4">
                            <!-- Toggle status button -->
                            <button onclick="toggleItemStatus('${item.id}', event)" class="flex items-center justify-center p-2 rounded-lg border border-slate-200 dark:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-800/60 text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-all text-sm" title="Quick Cycle Status">
                                <i class="fa-solid fa-arrows-spin"></i>
                            </button>
                            <!-- Edit -->
                            <button onclick="openEditModal('${item.id}', event)" class="flex items-center justify-center p-2 rounded-lg border border-slate-200 dark:border-slate-800 hover:bg-indigo-50 dark:hover:bg-indigo-950/20 text-indigo-500 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all text-sm" title="Edit Item">
                                <i class="fa-regular fa-pen-to-square"></i>
                            </button>
                            <!-- Delete -->
                            <button onclick="confirmDeleteItem('${item.id}', event)" class="flex items-center justify-center p-2 rounded-lg border border-slate-200 dark:border-slate-800 hover:bg-rose-50 dark:hover:bg-rose-950/20 text-rose-500 hover:text-rose-600 dark:hover:text-rose-400 transition-all text-sm" title="Remove Item">
                                <i class="fa-regular fa-trash-can"></i>
                            </button>
                        </div>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        function renderListView(items) {
            const tbody = document.getElementById('list-tbody');
            tbody.innerHTML = '';

            items.forEach(item => {
                const tr = document.createElement('tr');
                tr.className = "hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors";
                
                tr.innerHTML = `
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="flex items-center gap-3">
                            <!-- Minimal circular icon fallback -->
                            <div class="w-8 h-8 rounded-lg overflow-hidden shrink-0 border border-slate-200 dark:border-slate-700 bg-slate-100 dark:bg-slate-950">
                                ${item.image ? `<img src="${item.image}" alt="" class="w-full h-full object-cover" onerror="this.outerHTML='<div class=&quot;w-full h-full flex items-center justify-center text-xs bg-slate-300 dark:bg-slate-800&quot;><i class=&quot;fa-solid fa-image&quot;></i></div>'"/>` : `<div class="w-full h-full flex items-center justify-center text-xs bg-slate-300 dark:bg-slate-800"><i class="fa-solid fa-image"></i></div>`}
                            </div>
                            <div>
                                <div class="text-sm font-semibold text-slate-900 dark:text-white line-clamp-1">${item.title}</div>
                                <div class="text-[10px] text-slate-400">${item.year ? item.year : 'N/A'}</div>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                        ${getCategoryBadge(item.type)}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        ${getStatusBadge(item.status)}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                        ${getPriorityTag(item.priority)}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                        ${renderStars(item.rating)}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                        <div class="flex items-center justify-end gap-2">
                            <button onclick="toggleItemStatus('${item.id}', event)" class="p-1.5 text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-all" title="Cycle Status">
                                <i class="fa-solid fa-arrows-spin text-sm"></i>
                            </button>
                            <button onclick="openEditModal('${item.id}', event)" class="p-1.5 text-indigo-500 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all" title="Edit">
                                <i class="fa-regular fa-pen-to-square text-sm"></i>
                            </button>
                            <button onclick="confirmDeleteItem('${item.id}', event)" class="p-1.5 text-rose-500 hover:text-rose-600 dark:hover:text-rose-400 transition-all" title="Delete">
                                <i class="fa-regular fa-trash-can text-sm"></i>
                            </button>
                        </div>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function changeProgress(itemId, delta, event) {
            if (event) event.stopPropagation();
            const item = mediaItems.find(i => i.id === itemId);
            if (!item || item.type !== 'tv') return;

            const oldEp = item.episode || 0;
            const newEp = Math.max(0, oldEp + delta);
            item.episode = newEp;

            // Automatically transition status based on progress
            if (newEp > 0 && item.status === 'Not Started') {
                item.status = 'In Progress';
                showToast(`"${item.title}" is now In Progress!`, 'info');
            }

            saveToStorage();
            renderContent();
        }

        // Cycle through statuses easily
        function toggleItemStatus(itemId, event) {
            if (event) event.stopPropagation();
            const item = mediaItems.find(i => i.id === itemId);
            if (!item) return;

            const statuses = ['Not Started', 'In Progress', 'Completed', 'Abandoned'];
            const currentIndex = statuses.indexOf(item.status);
            const nextIndex = (currentIndex + 1) % statuses.length;
            item.status = statuses[nextIndex];

            // If completed, prompt/offer star updates or just set default high rating if previously 0
            if (item.status === 'Completed' && item.rating === 0) {
                item.rating = 4; // default initial completion rating
            }

            // Sync Game completion percentage
            if (item.type === 'game') {
                if (item.status === 'Completed') item.progress = 100;
                if (item.status === 'Not Started') item.progress = 0;
            }

            showToast(`Status updated to "${item.status}"`, 'success');
            saveToStorage();
            renderContent();
        }

        function openAddModal() {
            document.getElementById('modal-title').innerText = "Add New Entry";
            document.getElementById('media-form').reset();
            document.getElementById('item-id').value = "";
            setRatingValue(0);

            // Set media default values
            document.getElementById('item-type').value = "movie";
            document.getElementById('item-status').value = "Not Started";
            document.getElementById('item-priority').value = "Medium";

            adaptFormFields();
            showModal();
        }

        function openEditModal(itemId, event) {
            if (event) event.stopPropagation();
            const item = mediaItems.find(i => i.id === itemId);
            if (!item) return;

            document.getElementById('modal-title').innerText = "Edit Entry";
            document.getElementById('item-id').value = item.id;
            document.getElementById('item-title').value = item.title;
            document.getElementById('item-type').value = item.type;
            document.getElementById('item-status').value = item.status;
            document.getElementById('item-priority').value = item.priority;
            document.getElementById('item-year').value = item.year || '';
            document.getElementById('item-image').value = item.image || '';
            document.getElementById('item-notes').value = item.notes || '';
            setRatingValue(item.rating || 0);

            adaptFormFields();

            // Populate contextual fields
            if (item.type === 'movie') {
                document.getElementById('movie-director').value = item.director || '';
                document.getElementById('movie-runtime').value = item.runtime || '';
            } else if (item.type === 'tv') {
                document.getElementById('tv-season').value = item.season || 1;
                document.getElementById('tv-episode').value = item.episode || 0;
            } else if (item.type === 'game') {
                document.getElementById('game-platform').value = item.platform || '';
                document.getElementById('game-progress').value = item.progress || 0;
            } else if (item.type === 'music') {
                document.getElementById('music-artist').value = item.artist || '';
                document.getElementById('music-format').value = item.format || 'Album';
            }

            showModal();
        }

        function showModal() {
            const modal = document.getElementById('media-modal');
            const content = document.getElementById('modal-content');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            setTimeout(() => {
                content.classList.remove('scale-95');
                content.classList.add('scale-100');
            }, 10);
        }

        function closeModal() {
            const modal = document.getElementById('media-modal');
            const content = document.getElementById('modal-content');
            content.classList.remove('scale-100');
            content.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.remove('flex');
                modal.classList.add('hidden');
            }, 100);
        }

        // Adapt fields dynamically based on selecting media types
        function adaptFormFields() {
            const type = document.getElementById('item-type').value;
            
            // Hide all
            document.querySelectorAll('.dynamic-media-fields').forEach(el => el.classList.add('hidden'));

            // Show active
            const activeDiv = document.getElementById(`fields-${type}`);
            if (activeDiv) {
                activeDiv.classList.remove('hidden');
            }
        }

        // Interactive Star Rating selection in form
        function setRatingValue(rating) {
            document.getElementById('item-rating').value = rating;
            const starBtns = document.querySelectorAll('.star-btn');
            
            starBtns.forEach((btn, index) => {
                const starIcon = btn.querySelector('i');
                if (index < rating) {
                    starIcon.className = "fa-solid fa-star text-amber-400";
                } else {
                    starIcon.className = "fa-regular fa-star text-slate-300 dark:text-slate-700";
                }
            });
        }

        // Form Submit handler
        function handleFormSubmit(event) {
            event.preventDefault();

            const itemId = document.getElementById('item-id').value;
            const title = document.getElementById('item-title').value.trim();
            const type = document.getElementById('item-type').value;
            const status = document.getElementById('item-status').value;
            const priority = document.getElementById('item-priority').value;
            const rating = parseInt(document.getElementById('item-rating').value) || 0;
            const year = parseInt(document.getElementById('item-year').value) || null;
            const image = document.getElementById('item-image').value.trim();
            const notes = document.getElementById('item-notes').value.trim();

            if (!title) return;

            // Media specific properties
            const specifics = {};
            if (type === 'movie') {
                specifics.director = document.getElementById('movie-director').value.trim();
                specifics.runtime = parseInt(document.getElementById('movie-runtime').value) || null;
            } else if (type === 'tv') {
                specifics.season = parseInt(document.getElementById('tv-season').value) || 1;
                specifics.episode = parseInt(document.getElementById('tv-episode').value) || 0;
            } else if (type === 'game') {
                specifics.platform = document.getElementById('game-platform').value.trim();
                specifics.progress = parseInt(document.getElementById('game-progress').value) || 0;
            } else if (type === 'music') {
                specifics.artist = document.getElementById('music-artist').value.trim();
                specifics.format = document.getElementById('music-format').value;
            }

            if (itemId) {
                // Edit existing
                const index = mediaItems.findIndex(i => i.id === itemId);
                if (index !== -1) {
                    mediaItems[index] = {
                        ...mediaItems[index],
                        title, type, status, priority, rating, year, image, notes,
                        ...specifics
                    };
                    showToast(`Updated "${title}"`, 'success');
                }
            } else {
                // Create new
                const newItem = {
                    id: crypto.randomUUID(),
                    title, type, status, priority, rating, year, image, notes,
                    dateAdded: new Date().toISOString(),
                    ...specifics
                };
                mediaItems.push(newItem);
                showToast(`Added "${title}" to your shelf`, 'success');
            }

            saveToStorage();
            closeModal();
            renderContent();
        }

        function openDialog({ title, desc, iconBg, iconColor, iconClass, buttons }) {
            document.getElementById('dialog-title').innerText = title;
            document.getElementById('dialog-desc').innerText = desc;

            const iconContainer = document.getElementById('dialog-icon');
            iconContainer.className = `mx-auto w-12 h-12 rounded-full flex items-center justify-center text-xl mb-4 ${iconBg} ${iconColor}`;
            iconContainer.innerHTML = `<i class="${iconClass}"></i>`;

            const actionsContainer = document.getElementById('dialog-actions');
            actionsContainer.innerHTML = '';

            buttons.forEach(btn => {
                const button = document.createElement('button');
                button.className = `px-4 py-2 rounded-xl text-sm font-semibold transition-all ${btn.styleClass}`;
                button.innerText = btn.text;
                button.onclick = () => {
                    closeDialog();
                    if (btn.action) btn.action();
                };
                actionsContainer.appendChild(button);
            });

            const dialog = document.getElementById('dialog-modal');
            const content = document.getElementById('dialog-content');
            dialog.classList.remove('hidden');
            dialog.classList.add('flex');
            setTimeout(() => {
                content.classList.remove('scale-95');
                content.classList.add('scale-100');
            }, 10);
        }

        function closeDialog() {
            const dialog = document.getElementById('dialog-modal');
            const content = document.getElementById('dialog-content');
            content.classList.remove('scale-100');
            content.classList.add('scale-95');
            setTimeout(() => {
                dialog.classList.remove('flex');
                dialog.classList.add('hidden');
            }, 100);
        }

        // Safe Confirmation for Deleting Items
        function confirmDeleteItem(itemId, event) {
            if (event) event.stopPropagation();
            const item = mediaItems.find(i => i.id === itemId);
            if (!item) return;

            openDialog({
                title: "Delete Backlog Item?",
                desc: `Are you absolutely sure you want to remove "${item.title}" from your shelf? This action cannot be undone.`,
                iconBg: "bg-rose-100 dark:bg-rose-950/40",
                iconColor: "text-rose-600 dark:text-rose-400",
                iconClass: "fa-regular fa-trash-can",
                buttons: [
                    {
                        text: "Cancel",
                        styleClass: "border border-slate-200 dark:border-slate-800 hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-700 dark:text-slate-300"
                    },
                    {
                        text: "Delete",
                        styleClass: "bg-rose-600 hover:bg-rose-700 text-white shadow-lg shadow-rose-600/10",
                        action: () => {
                            mediaItems = mediaItems.filter(i => i.id !== itemId);
                            saveToStorage();
                            renderContent();
                            showToast(`Removed "${item.title}"`, 'error');
                        }
                    }
                ]
            });
        }

        function pickRandomItem() {
            // Find high or medium priority items not yet started
            let candidates = mediaItems.filter(i => i.status === 'Not Started' && i.priority !== 'Low');
            
            // Fallback to any unstarted if no high priority candidates
            if (candidates.length === 0) {
                candidates = mediaItems.filter(i => i.status === 'Not Started');
            }

            // Fallback to in-progress if fully completed/empty
            if (candidates.length === 0) {
                candidates = mediaItems.filter(i => i.status === 'In Progress');
            }

            if (candidates.length === 0) {
                openDialog({
                    title: "Shelf is Empty!",
                    desc: "Add some items you want to watch, play, or listen to first so we can pick one for you!",
                    iconBg: "bg-indigo-100 dark:bg-indigo-950/40",
                    iconColor: "text-indigo-600 dark:text-indigo-400",
                    iconClass: "fa-solid fa-box-open",
                    buttons: [{
                        text: "Perfect",
                        styleClass: "bg-indigo-600 hover:bg-indigo-700 text-white shadow-lg shadow-indigo-600/10"
                    }]
                });
                return;
            }

            const chosen = candidates[Math.floor(Math.random() * candidates.length)];
            const typeEmoji = { movie: '🎬', tv: '📺', game: '🎮', music: '🎵' }[chosen.type];

            openDialog({
                title: "Your Next Adventure! 🎲",
                desc: `We selected "${chosen.title}" (${chosen.type.toUpperCase()}) for you to start next! It has ${chosen.priority} priority. Let's dig in!`,
                iconBg: "bg-emerald-100 dark:bg-emerald-950/40",
                iconColor: "text-emerald-600 dark:text-emerald-400",
                iconClass: "fa-solid fa-dice-five",
                buttons: [
                    {
                        text: "Roll Again",
                        styleClass: "border border-slate-200 dark:border-slate-800 hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-700 dark:text-slate-300",
                        action: () => setTimeout(pickRandomItem, 150)
                    },
                    {
                        text: "Start Watch/Play!",
                        styleClass: "bg-emerald-600 hover:bg-emerald-700 text-white shadow-lg shadow-emerald-600/10",
                        action: () => {
                            chosen.status = "In Progress";
                            saveToStorage();
                            renderContent();
                            showToast(`"${chosen.title}" is now In Progress!`, 'success');
                        }
                    }
                ]
            });
        }

        window.onload = function() {
            initTheme();
            updateStatsDashboard();
            renderContent();
        }
    </script>
</body>
</html>
